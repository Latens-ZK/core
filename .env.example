# Latens — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Backend ───────────────────────────────────────────────────────────────────

# SQLite (dev) or PostgreSQL (prod)
DATABASE_URL=sqlite:///./latens.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Minimum balance to include in snapshots (satoshis, default: 10000 = 0.0001 BTC)
MIN_BALANCE_SATOSHIS=10000

# ─── Bitcoin Data ──────────────────────────────────────────────────────────────

# Blockstream API (public, no key required)
BLOCKSTREAM_API_URL=https://blockstream.info/api

# ─── Starknet ─────────────────────────────────────────────────────────────────

# RPC endpoint (free public Starknet Sepolia RPC)
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io

# Your Starknet account for deploying contracts and updating roots
STARKNET_ACCOUNT_ADDRESS=0x...
STARKNET_PRIVATE_KEY=0x...

# ─── Contract Addresses (set after running contracts/scripts/deploy.py) ────────

STATE_ROOT_REGISTRY_ADDRESS=0x...
BALANCE_VERIFIER_ADDRESS=0x...

# ─── Frontend (copy/paste into frontend/.env.local too) ───────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_VERIFIER_ADDRESS=0x...
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
