# ────────────────────────────────────────────────────────────────────────────
# Latens — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────

# SQLite (default, works with zero setup)
DATABASE_URL=sqlite:////app/data/latens.db

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Blockstream public API — no key required
BLOCKSTREAM_API_URL=https://blockstream.info/api

# Optional: comma-separated Bitcoin addresses to monitor (defaults to demo set)
# MONITORED_ADDRESSES=1A1zP1...,34xp4v...

# ── Starknet Sepolia ──────────────────────────────────────────────────────────
# Required to run: cd contracts/scripts && node deploy.mjs
# Get a free Sepolia account + STRK: https://faucet.starknet.io

STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io
STARKNET_PRIVATE_KEY=
STARKNET_ACCOUNT_ADDRESS=

# Filled automatically by deploy.mjs — or set manually after deployment
STATE_ROOT_REGISTRY_ADDRESS=
BALANCE_VERIFIER_ADDRESS=
DAO_GATE_ADDRESS=

# ── Frontend (baked into Next.js static bundle at Docker build time) ──────────
# If VERIFIER/REGISTRY addresses are empty, on-chain verify is disabled until
# you rebuild the frontend image with the real addresses set here.

NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_VERIFIER_ADDRESS=
NEXT_PUBLIC_REGISTRY_ADDRESS=
